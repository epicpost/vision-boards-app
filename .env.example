# Base URL for the EpicPost API
VITE_API_BASE_URL=https://epicapi.epicpost.app

# Google OAuth 2.0 Web client ID (from Google Cloud Console > Credentials).
# Add your site origins to the client's "Authorized JavaScript origins".
VITE_GOOGLE_CLIENT_ID=

# Comma-separated extra hosts the same-origin image proxy may fetch
# (lib/image-proxy.ts). Remix/generated photos live on S3, whose host is NOT
# epicpost.app — without this the proxy rejects them, the editor falls back to
# the raw cross-origin URL, and canvas export drops every photo (black export).
# Include the API upload bucket host AND the render output bucket host.
VITE_IMAGE_PROXY_HOSTS=epicpost-prod-generated-assets.s3.us-east-1.amazonaws.com
